# ALSA configuration for Plum Snapcast
# Enables dmix (device mixing) to allow multiple snapclients to share audio hardware

# Define the dmix plugin for the Headphones card
pcm.dmixer {
    type dmix
    ipc_key 1024
    ipc_perm 0666
    slave {
        pcm "hw:Headphones,0"
        period_time 0
        period_size 1024
        buffer_size 4096
        rate 48000
        format S16_LE
        channels 2
    }
    bindings {
        0 0
        1 1
    }
}

# Make dmix the default device
pcm.!default {
    type plug
    slave.pcm "dmixer"
}

# Make hw:Headphones an alias for dmix (allows local snapclient to share device)
pcm.Headphones {
    type plug
    slave.pcm "dmixer"
}

# Control device (for volume control)
ctl.!default {
    type hw
    card 0
}
