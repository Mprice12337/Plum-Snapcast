# Docker Hub username for pushing images
DOCKER_USERNAME=your-dockerhub-username

# Timezone
TZ=America/Los_Angeles

# ============================================================================
# INTEGRATION SETTINGS (AirPlay, Bluetooth, Spotify, DLNA)
# ============================================================================
# NOTE: Integration settings are now managed via the web UI!
# Go to Settings → Integrations to configure:
#   - Enable/disable sources
#   - Set device names
#   - Configure bitrates, pairing, etc.
#
# The settings below are ONLY used for initial setup or migration.
# On first start, these will be migrated to /app/data/settings.json
# After that, all changes should be made through the web UI.
# ============================================================================

# AirPlay Configuration
AIRPLAY_DEVICE_NAME=Plum Audio

# Bluetooth Configuration (optional)
BLUETOOTH_ENABLED=0
BLUETOOTH_DEVICE_NAME=Plum Audio
BLUETOOTH_ADAPTER=hci0
# BLUETOOTH_DEVICE_PATH=/dev/hci0  # Optional: Specify custom Bluetooth device path
BLUETOOTH_AUTO_PAIR=1
BLUETOOTH_DISCOVERABLE=1

# Spotify Configuration (optional)
SPOTIFY_CONFIG_ENABLED=0
SPOTIFY_SOURCE_NAME=Spotify
SPOTIFY_DEVICE_NAME=Plum Audio
SPOTIFY_BITRATE=320

# DLNA/UPnP Configuration (optional)
DLNA_ENABLED=0
DLNA_SOURCE_NAME=DLNA
DLNA_DEVICE_NAME=Plum Audio
# DLNA_UUID=  # Optional: Specify custom UPnP UUID

# Plexamp Configuration (optional, requires Plex Pass)
PLEXAMP_ENABLED=0
PLEXAMP_SOURCE_NAME=Plexamp
PLEXAMP_CLAIM_TOKEN=
PLEXAMP_SERVER_NAME=Plum Audio

# Snapclient Configuration
SNAPCLIENT_SOUNDCARD=hw:Headphones

# Frontend Configuration
FRONTEND_PORT=3000
SNAPCAST_HOST=localhost
SNAPCAST_PORT=1704

# ============================================================================
# FEDERATION CONFIGURATION (multi-server control)
# ============================================================================
# NOTE: Federation settings (except API port) are now managed via the web UI!
# Go to Settings → Federation to configure:
#   - Enable/disable federation
#   - Set local server name
#   - Configure auto-discovery
#
# Like integration settings, these are migrated to settings.json on first start.
# ============================================================================

FEDERATION_ENABLED=0
FEDERATION_AUTO_DISCOVER=1
FEDERATION_LOCAL_NAME=Main Server
FEDERATION_API_PORT=5001
# FEDERATION_MANUAL_SERVERS=[{"host":"192.168.7.226","port":1780,"name":"Music Assistant"}]

# Hostname for SSL certificate
HOSTNAME=raspberrypi