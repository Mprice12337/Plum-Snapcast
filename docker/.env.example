# Docker Hub username for pushing images
DOCKER_USERNAME=your-dockerhub-username

# Timezone
TZ=America/Los_Angeles

# ============================================================================
# INTEGRATION SETTINGS
# ============================================================================

# Plexamp Configuration (optional, requires Plex Pass)
# NOTE: Plexamp runs in a separate container and requires env configuration
PLEXAMP_ENABLED=0
PLEXAMP_SOURCE_NAME=Plexamp
PLEXAMP_CLAIM_TOKEN=
PLEXAMP_SERVER_NAME=Plum Audio

# AirPlay Idle Timeout Configuration
# Controls how long to keep stream alive after pause/idle (in seconds)
# Immediate disconnect cleanup happens regardless of this setting (via MQTT active_end)
# Default: 300 (5 minutes)
AIRPLAY_IDLE_TIMEOUT=300

# Snapclient Configuration
# NOTE: Audio output device is now configured via GUI (Settings → Audio)
# SNAPCLIENT_SOUNDCARD is deprecated and will be migrated to settings.json automatically
# Only needed for initial setup; will default to hw:Headphones
# SNAPCLIENT_SOUNDCARD=hw:Headphones

# Frontend Configuration
FRONTEND_PORT=3000
SNAPCAST_HOST=localhost
SNAPCAST_PORT=1704

# ============================================================================
# FEDERATION CONFIGURATION (multi-server control)
# ============================================================================
FEDERATION_API_PORT=5001