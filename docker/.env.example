# Docker Hub username for pushing images
DOCKER_USERNAME=your-dockerhub-username

# Timezone
TZ=America/Los_Angeles

# ============================================================================
# INTEGRATION SETTINGS
# ============================================================================

# Plexamp Configuration (optional, requires Plex Pass)
# NOTE: Plexamp runs in a separate container and requires env configuration
PLEXAMP_ENABLED=0
PLEXAMP_SOURCE_NAME=Plexamp
PLEXAMP_CLAIM_TOKEN=
PLEXAMP_SERVER_NAME=Plum Audio

# Snapclient Configuration (hardware-specific, set at deployment)
SNAPCLIENT_SOUNDCARD=hw:Headphones

# Frontend Configuration
FRONTEND_PORT=3000
SNAPCAST_HOST=localhost
SNAPCAST_PORT=1704

# ============================================================================
# FEDERATION CONFIGURATION (multi-server control)
# ============================================================================
FEDERATION_API_PORT=5001